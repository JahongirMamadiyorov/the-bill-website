# Copy this file to .env.local to override dev defaults.
#
# By default, `npm run dev` proxies /api and /uploads to the production
# Render backend (https://the-bill-backend.onrender.com), so the website
# loads real data without running anything locally.
#
# If you want to point the Vite dev proxy at a LOCAL backend instead
# (for testing backend changes), uncomment the line below and start the
# backend with:
#   cd ../restaurant-app/backend && npm run dev
#
# VITE_DEV_PROXY=http://localhost:3000
#
# If you want to bypass the Vite proxy entirely and hit some other URL
# directly from the browser (not recommended — CORS will likely block it),
# uncomment and set:
#
# VITE_API_URL=http://localhost:3000/api
